<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsInboundMapper">
    
    <resultMap type="ImsInbound" id="ImsInboundResult">
        <result property="id"    column="id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="billDate"    column="bill_date"    />
        <result property="inType"    column="in_type"    />
        <result property="enterpriseId"    column="enterprise_id"    />
        <result property="enterpriseName"    column="enterprise_name"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="warehouseName"    column="warehouse_name"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="supplierName"    column="supplier_name"    />
        <result property="customerId"    column="customer_id"    />
        <result property="customerName"    column="customer_name"    />
        <result property="handlerId"    column="handler_id"    />
        <result property="handlerName"    column="handler_name"    />
        <result property="totalQtyPiece"    column="total_qty_piece"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="billStatus"    column="bill_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="ImsInboundImsInboundItemResult" type="ImsInbound" extends="ImsInboundResult">
        <collection property="imsInboundItemList" ofType="ImsInboundItem" column="id" select="selectImsInboundItemList" />
    </resultMap>

    <resultMap type="ImsInboundItem" id="ImsInboundItemResult">
        <result property="id"    column="id"    />
        <result property="inboundId"    column="inbound_id"    />
        <result property="lineNo"    column="line_no"    />
        <result property="productId"    column="product_id"    />
        <result property="qtyPiece"    column="qty_piece"    />
        <result property="unitPrice"    column="unit_price"    />
        <result property="amount"    column="amount"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsInboundVo">
        select i.id, i.bill_no, i.bill_date, i.in_type, i.enterprise_id, e.enterprise_name,
               i.warehouse_id, w.warehouse_name, i.supplier_id, s.supplier_name,
               i.customer_id, c.customer_name, i.handler_id, emp.employee_name as handler_name,
               i.total_qty_piece, i.total_amount, i.bill_status, i.create_by, i.create_time,
               i.update_by, i.update_time, i.remark
        from ims_inbound i
        left join ims_enterprise e on i.enterprise_id = e.id
        left join ims_warehouse w on i.warehouse_id = w.id
        left join ims_supplier s on i.supplier_id = s.id
        left join ims_customer c on i.customer_id = c.id
        left join ims_employee emp on i.handler_id = emp.id
    </sql>

    <select id="selectImsInboundList" parameterType="ImsInbound" resultMap="ImsInboundResult">
        <include refid="selectImsInboundVo"/>
        <where>  
            <if test="billNo != null  and billNo != ''"> and i.bill_no = #{billNo}</if>
            <if test="billDate != null and params.beginBillDate == null and params.endBillDate == null"> and i.bill_date = #{billDate}</if>
            <if test="params.beginBillDate != null and params.beginBillDate != ''"> and date_format(i.bill_date,'%Y%m%d') &gt;= date_format(#{params.beginBillDate},'%Y%m%d')</if>
            <if test="params.endBillDate != null and params.endBillDate != ''"> and date_format(i.bill_date,'%Y%m%d') &lt;= date_format(#{params.endBillDate},'%Y%m%d')</if>
            <if test="inType != null  and inType != ''"> and i.in_type = #{inType}</if>
            <if test="enterpriseId != null "> and i.enterprise_id = #{enterpriseId}</if>
            <if test="warehouseId != null "> and i.warehouse_id = #{warehouseId}</if>
            <if test="supplierId != null "> and i.supplier_id = #{supplierId}</if>
            <if test="customerId != null "> and i.customer_id = #{customerId}</if>
            <if test="handlerId != null "> and i.handler_id = #{handlerId}</if>
            <if test="billStatus != null  and billStatus != ''"> and i.bill_status = #{billStatus}</if>
        </where>
        order by i.bill_date desc, i.create_time desc, i.id desc
    </select>
    
    <select id="selectImsInboundById" parameterType="Long" resultMap="ImsInboundImsInboundItemResult">
        select id, bill_no, bill_date, in_type, enterprise_id, warehouse_id, supplier_id, customer_id, handler_id, total_qty_piece, total_amount, bill_status, create_by, create_time, update_by, update_time, remark
        from ims_inbound
        where id = #{id}
    </select>

    <select id="selectImsInboundItemList" resultMap="ImsInboundItemResult">
        select id, inbound_id, line_no, product_id, qty_piece, unit_price, amount, remark
        from ims_inbound_item
        where inbound_id = #{inbound_id}
    </select>

    <insert id="insertImsInbound" parameterType="ImsInbound" useGeneratedKeys="true" keyProperty="id">
        insert into ims_inbound
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="billDate != null">bill_date,</if>
            <if test="inType != null and inType != ''">in_type,</if>
            <if test="enterpriseId != null">enterprise_id,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="handlerId != null">handler_id,</if>
            <if test="totalQtyPiece != null">total_qty_piece,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="billStatus != null and billStatus != ''">bill_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="billDate != null">#{billDate},</if>
            <if test="inType != null and inType != ''">#{inType},</if>
            <if test="enterpriseId != null">#{enterpriseId},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="handlerId != null">#{handlerId},</if>
            <if test="totalQtyPiece != null">#{totalQtyPiece},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">#{billStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsInbound" parameterType="ImsInbound">
        update ims_inbound
        <trim prefix="SET" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="billDate != null">bill_date = #{billDate},</if>
            <if test="inType != null and inType != ''">in_type = #{inType},</if>
            <if test="enterpriseId != null">enterprise_id = #{enterpriseId},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="handlerId != null">handler_id = #{handlerId},</if>
            <if test="totalQtyPiece != null">total_qty_piece = #{totalQtyPiece},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">bill_status = #{billStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsInboundById" parameterType="Long">
        delete from ims_inbound where id = #{id}
    </delete>

    <delete id="deleteImsInboundByIds" parameterType="String">
        delete from ims_inbound where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteImsInboundItemByInboundIds" parameterType="String">
        delete from ims_inbound_item where inbound_id in 
        <foreach item="inboundId" collection="array" open="(" separator="," close=")">
            #{inboundId}
        </foreach>
    </delete>

    <delete id="deleteImsInboundItemByInboundId" parameterType="Long">
        delete from ims_inbound_item where inbound_id = #{inboundId}
    </delete>

    <insert id="batchImsInboundItem">
        insert into ims_inbound_item( id, inbound_id, line_no, product_id, qty_piece, unit_price, amount, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.inboundId}, #{item.lineNo}, #{item.productId}, #{item.qtyPiece}, #{item.unitPrice}, #{item.amount}, #{item.remark})
        </foreach>
    </insert>
</mapper>
