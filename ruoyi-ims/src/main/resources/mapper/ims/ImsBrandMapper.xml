<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsBrandMapper">
    
    <resultMap type="ImsBrand" id="ImsBrandResult">
        <result property="id"    column="id"    />
        <result property="brandCode"    column="brand_code"    />
        <result property="brandName"    column="brand_name"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsBrandVo">
        select id, brand_code, brand_name, status, create_by, create_time, update_by, update_time, remark from ims_brand
    </sql>

    <select id="selectImsBrandList" parameterType="ImsBrand" resultMap="ImsBrandResult">
        <include refid="selectImsBrandVo"/>
        <where>  
            <if test="brandCode != null  and brandCode != ''"> and brand_code = #{brandCode}</if>
            <if test="brandName != null  and brandName != ''"> and brand_name like concat('%', #{brandName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc, id desc
    </select>
    
    <select id="selectImsBrandById" parameterType="Long" resultMap="ImsBrandResult">
        <include refid="selectImsBrandVo"/>
        where id = #{id}
    </select>

    <insert id="insertImsBrand" parameterType="ImsBrand" useGeneratedKeys="true" keyProperty="id">
        insert into ims_brand
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="brandCode != null and brandCode != ''">brand_code,</if>
            <if test="brandName != null and brandName != ''">brand_name,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="brandCode != null and brandCode != ''">#{brandCode},</if>
            <if test="brandName != null and brandName != ''">#{brandName},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsBrand" parameterType="ImsBrand">
        update ims_brand
        <trim prefix="SET" suffixOverrides=",">
            <if test="brandCode != null and brandCode != ''">brand_code = #{brandCode},</if>
            <if test="brandName != null and brandName != ''">brand_name = #{brandName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsBrandById" parameterType="Long">
        delete from ims_brand where id = #{id}
    </delete>

    <delete id="deleteImsBrandByIds" parameterType="String">
        delete from ims_brand where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
