<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsOutboundMapper">
    
    <resultMap type="ImsOutbound" id="ImsOutboundResult">
        <result property="id"    column="id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="billDate"    column="bill_date"    />
        <result property="outType"    column="out_type"    />
        <result property="enterpriseId"    column="enterprise_id"    />
        <result property="enterpriseName"    column="enterprise_name"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="warehouseName"    column="warehouse_name"    />
        <result property="customerId"    column="customer_id"    />
        <result property="customerName"    column="customer_name"    />
        <result property="handlerId"    column="handler_id"    />
        <result property="handlerName"    column="handler_name"    />
        <result property="totalQtyPiece"    column="total_qty_piece"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="billStatus"    column="bill_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="ImsOutboundImsOutboundItemResult" type="ImsOutbound" extends="ImsOutboundResult">
        <collection property="imsOutboundItemList" ofType="ImsOutboundItem" column="id" select="selectImsOutboundItemList" />
    </resultMap>

    <resultMap type="ImsOutboundItem" id="ImsOutboundItemResult">
        <result property="id"    column="id"    />
        <result property="outboundId"    column="outbound_id"    />
        <result property="lineNo"    column="line_no"    />
        <result property="productId"    column="product_id"    />
        <result property="qtyPiece"    column="qty_piece"    />
        <result property="unitPrice"    column="unit_price"    />
        <result property="amount"    column="amount"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsOutboundVo">
        select o.id, o.bill_no, o.bill_date, o.out_type, o.enterprise_id, e.enterprise_name,
               o.warehouse_id, w.warehouse_name, o.customer_id, c.customer_name,
               o.handler_id, emp.employee_name as handler_name, o.total_qty_piece,
               o.total_amount, o.bill_status, o.create_by, o.create_time, o.update_by,
               o.update_time, o.remark
        from ims_outbound o
        left join ims_enterprise e on o.enterprise_id = e.id
        left join ims_warehouse w on o.warehouse_id = w.id
        left join ims_customer c on o.customer_id = c.id
        left join ims_employee emp on o.handler_id = emp.id
    </sql>

    <select id="selectImsOutboundList" parameterType="ImsOutbound" resultMap="ImsOutboundResult">
        <include refid="selectImsOutboundVo"/>
        <where>  
            <if test="billNo != null  and billNo != ''"> and o.bill_no = #{billNo}</if>
            <if test="billDate != null and params.beginBillDate == null and params.endBillDate == null"> and o.bill_date = #{billDate}</if>
            <if test="params.beginBillDate != null and params.beginBillDate != ''"> and date_format(o.bill_date,'%Y%m%d') &gt;= date_format(#{params.beginBillDate},'%Y%m%d')</if>
            <if test="params.endBillDate != null and params.endBillDate != ''"> and date_format(o.bill_date,'%Y%m%d') &lt;= date_format(#{params.endBillDate},'%Y%m%d')</if>
            <if test="outType != null  and outType != ''"> and o.out_type = #{outType}</if>
            <if test="enterpriseId != null "> and o.enterprise_id = #{enterpriseId}</if>
            <if test="warehouseId != null "> and o.warehouse_id = #{warehouseId}</if>
            <if test="customerId != null "> and o.customer_id = #{customerId}</if>
            <if test="handlerId != null "> and o.handler_id = #{handlerId}</if>
            <if test="billStatus != null  and billStatus != ''"> and o.bill_status = #{billStatus}</if>
        </where>
        order by o.bill_date desc, o.create_time desc, o.id desc
    </select>
    
    <select id="selectImsOutboundById" parameterType="Long" resultMap="ImsOutboundImsOutboundItemResult">
        select id, bill_no, bill_date, out_type, enterprise_id, warehouse_id, customer_id, handler_id, total_qty_piece, total_amount, bill_status, create_by, create_time, update_by, update_time, remark
        from ims_outbound
        where id = #{id}
    </select>

    <select id="selectImsOutboundItemList" resultMap="ImsOutboundItemResult">
        select id, outbound_id, line_no, product_id, qty_piece, unit_price, amount, remark
        from ims_outbound_item
        where outbound_id = #{outbound_id}
    </select>

    <insert id="insertImsOutbound" parameterType="ImsOutbound" useGeneratedKeys="true" keyProperty="id">
        insert into ims_outbound
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="billDate != null">bill_date,</if>
            <if test="outType != null and outType != ''">out_type,</if>
            <if test="enterpriseId != null">enterprise_id,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="handlerId != null">handler_id,</if>
            <if test="totalQtyPiece != null">total_qty_piece,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="billStatus != null and billStatus != ''">bill_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="billDate != null">#{billDate},</if>
            <if test="outType != null and outType != ''">#{outType},</if>
            <if test="enterpriseId != null">#{enterpriseId},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="handlerId != null">#{handlerId},</if>
            <if test="totalQtyPiece != null">#{totalQtyPiece},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">#{billStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsOutbound" parameterType="ImsOutbound">
        update ims_outbound
        <trim prefix="SET" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="billDate != null">bill_date = #{billDate},</if>
            <if test="outType != null and outType != ''">out_type = #{outType},</if>
            <if test="enterpriseId != null">enterprise_id = #{enterpriseId},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="handlerId != null">handler_id = #{handlerId},</if>
            <if test="totalQtyPiece != null">total_qty_piece = #{totalQtyPiece},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">bill_status = #{billStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsOutboundById" parameterType="Long">
        delete from ims_outbound where id = #{id}
    </delete>

    <delete id="deleteImsOutboundByIds" parameterType="String">
        delete from ims_outbound where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteImsOutboundItemByOutboundIds" parameterType="String">
        delete from ims_outbound_item where outbound_id in 
        <foreach item="outboundId" collection="array" open="(" separator="," close=")">
            #{outboundId}
        </foreach>
    </delete>

    <delete id="deleteImsOutboundItemByOutboundId" parameterType="Long">
        delete from ims_outbound_item where outbound_id = #{outboundId}
    </delete>

    <insert id="batchImsOutboundItem">
        insert into ims_outbound_item( id, outbound_id, line_no, product_id, qty_piece, unit_price, amount, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.outboundId}, #{item.lineNo}, #{item.productId}, #{item.qtyPiece}, #{item.unitPrice}, #{item.amount}, #{item.remark})
        </foreach>
    </insert>
</mapper>
