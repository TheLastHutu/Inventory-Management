<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsFixedAssetMapper">
    
    <resultMap type="ImsFixedAsset" id="ImsFixedAssetResult">
        <result property="id"    column="id"    />
        <result property="enterpriseId"    column="enterprise_id"    />
        <result property="enterpriseName"    column="enterprise_name"    />
        <result property="assetCode"    column="asset_code"    />
        <result property="assetName"    column="asset_name"    />
        <result property="assetCategory"    column="asset_category"    />
        <result property="purchaseDate"    column="purchase_date"    />
        <result property="originalValue"    column="original_value"    />
        <result property="netValue"    column="net_value"    />
        <result property="useDept"    column="use_dept"    />
        <result property="keeper"    column="keeper"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsFixedAssetVo">
        select a.id, a.enterprise_id, e.enterprise_name, a.asset_code, a.asset_name,
               a.asset_category, a.purchase_date, a.original_value, a.net_value,
               a.use_dept, a.keeper, a.status, a.create_by, a.create_time,
               a.update_by, a.update_time, a.remark
        from ims_fixed_asset a
        left join ims_enterprise e on a.enterprise_id = e.id
    </sql>

    <select id="selectImsFixedAssetList" parameterType="ImsFixedAsset" resultMap="ImsFixedAssetResult">
        <include refid="selectImsFixedAssetVo"/>
        <where>  
            <if test="enterpriseId != null "> and a.enterprise_id = #{enterpriseId}</if>
            <if test="assetCode != null  and assetCode != ''"> and a.asset_code = #{assetCode}</if>
            <if test="assetName != null  and assetName != ''"> and a.asset_name like concat('%', #{assetName}, '%')</if>
            <if test="assetCategory != null  and assetCategory != ''"> and a.asset_category = #{assetCategory}</if>
            <if test="purchaseDate != null and params.beginPurchaseDate == null and params.endPurchaseDate == null"> and a.purchase_date = #{purchaseDate}</if>
            <if test="params.beginPurchaseDate != null and params.beginPurchaseDate != ''"> and date_format(a.purchase_date,'%Y%m%d') &gt;= date_format(#{params.beginPurchaseDate},'%Y%m%d')</if>
            <if test="params.endPurchaseDate != null and params.endPurchaseDate != ''"> and date_format(a.purchase_date,'%Y%m%d') &lt;= date_format(#{params.endPurchaseDate},'%Y%m%d')</if>
            <if test="useDept != null  and useDept != ''"> and a.use_dept = #{useDept}</if>
            <if test="keeper != null  and keeper != ''"> and a.keeper = #{keeper}</if>
            <if test="status != null  and status != ''"> and a.status = #{status}</if>
        </where>
        order by a.purchase_date desc, a.create_time desc, a.id desc
    </select>
    
    <select id="selectImsFixedAssetById" parameterType="Long" resultMap="ImsFixedAssetResult">
        <include refid="selectImsFixedAssetVo"/>
        where a.id = #{id}
    </select>

    <insert id="insertImsFixedAsset" parameterType="ImsFixedAsset" useGeneratedKeys="true" keyProperty="id">
        insert into ims_fixed_asset
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="enterpriseId != null">enterprise_id,</if>
            <if test="assetCode != null and assetCode != ''">asset_code,</if>
            <if test="assetName != null and assetName != ''">asset_name,</if>
            <if test="assetCategory != null">asset_category,</if>
            <if test="purchaseDate != null">purchase_date,</if>
            <if test="originalValue != null">original_value,</if>
            <if test="netValue != null">net_value,</if>
            <if test="useDept != null">use_dept,</if>
            <if test="keeper != null">keeper,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="enterpriseId != null">#{enterpriseId},</if>
            <if test="assetCode != null and assetCode != ''">#{assetCode},</if>
            <if test="assetName != null and assetName != ''">#{assetName},</if>
            <if test="assetCategory != null">#{assetCategory},</if>
            <if test="purchaseDate != null">#{purchaseDate},</if>
            <if test="originalValue != null">#{originalValue},</if>
            <if test="netValue != null">#{netValue},</if>
            <if test="useDept != null">#{useDept},</if>
            <if test="keeper != null">#{keeper},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsFixedAsset" parameterType="ImsFixedAsset">
        update ims_fixed_asset
        <trim prefix="SET" suffixOverrides=",">
            <if test="enterpriseId != null">enterprise_id = #{enterpriseId},</if>
            <if test="assetCode != null and assetCode != ''">asset_code = #{assetCode},</if>
            <if test="assetName != null and assetName != ''">asset_name = #{assetName},</if>
            <if test="assetCategory != null">asset_category = #{assetCategory},</if>
            <if test="purchaseDate != null">purchase_date = #{purchaseDate},</if>
            <if test="originalValue != null">original_value = #{originalValue},</if>
            <if test="netValue != null">net_value = #{netValue},</if>
            <if test="useDept != null">use_dept = #{useDept},</if>
            <if test="keeper != null">keeper = #{keeper},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsFixedAssetById" parameterType="Long">
        delete from ims_fixed_asset where id = #{id}
    </delete>

    <delete id="deleteImsFixedAssetByIds" parameterType="String">
        delete from ims_fixed_asset where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
