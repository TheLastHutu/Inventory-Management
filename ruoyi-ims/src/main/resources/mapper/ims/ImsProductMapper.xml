<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsProductMapper">
    
    <resultMap type="ImsProduct" id="ImsProductResult">
        <result property="id"    column="id"    />
        <result property="productCode"    column="product_code"    />
        <result property="productName"    column="product_name"    />
        <result property="categoryId"    column="category_id"    />
        <result property="categoryName"    column="category_name"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="supplierName"    column="supplier_name"    />
        <result property="unitId"    column="unit_id"    />
        <result property="unitName"    column="unit_name"    />
        <result property="brandId"    column="brand_id"    />
        <result property="brandName"    column="brand_name"    />
        <result property="spec"    column="spec"    />
        <result property="colorNo"    column="color_no"    />
        <result property="grade"    column="grade"    />
        <result property="boxRate"    column="box_rate"    />
        <result property="purchasePrice"    column="purchase_price"    />
        <result property="salePrice"    column="sale_price"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsProductVo">
        select p.id, p.product_code, p.product_name, p.category_id, pc.category_name,
               p.supplier_id, s.supplier_name, p.unit_id, u.unit_name, p.brand_id, b.brand_name,
               p.spec, p.color_no, p.grade, p.box_rate, p.purchase_price, p.sale_price,
               p.status, p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from ims_product p
        left join ims_product_category pc on p.category_id = pc.id
        left join ims_supplier s on p.supplier_id = s.id
        left join ims_unit u on p.unit_id = u.id
        left join ims_brand b on p.brand_id = b.id
    </sql>

    <select id="selectImsProductList" parameterType="ImsProduct" resultMap="ImsProductResult">
        <include refid="selectImsProductVo"/>
        <where>  
            <if test="productCode != null  and productCode != ''"> and p.product_code = #{productCode}</if>
            <if test="productName != null  and productName != ''"> and p.product_name like concat('%', #{productName}, '%')</if>
            <if test="categoryId != null "> and p.category_id = #{categoryId}</if>
            <if test="supplierId != null "> and p.supplier_id = #{supplierId}</if>
            <if test="unitId != null "> and p.unit_id = #{unitId}</if>
            <if test="brandId != null "> and p.brand_id = #{brandId}</if>
            <if test="spec != null  and spec != ''"> and p.spec = #{spec}</if>
            <if test="colorNo != null  and colorNo != ''"> and p.color_no = #{colorNo}</if>
            <if test="grade != null  and grade != ''"> and p.grade = #{grade}</if>
            <if test="status != null  and status != ''"> and p.status = #{status}</if>
        </where>
        order by p.create_time desc, p.id desc
    </select>
    
    <select id="selectImsProductById" parameterType="Long" resultMap="ImsProductResult">
        <include refid="selectImsProductVo"/>
        where p.id = #{id}
    </select>

    <insert id="insertImsProduct" parameterType="ImsProduct" useGeneratedKeys="true" keyProperty="id">
        insert into ims_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="productCode != null and productCode != ''">product_code,</if>
            <if test="productName != null">product_name,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="brandId != null">brand_id,</if>
            <if test="spec != null">spec,</if>
            <if test="colorNo != null">color_no,</if>
            <if test="grade != null">grade,</if>
            <if test="boxRate != null">box_rate,</if>
            <if test="purchasePrice != null">purchase_price,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="productCode != null and productCode != ''">#{productCode},</if>
            <if test="productName != null">#{productName},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="brandId != null">#{brandId},</if>
            <if test="spec != null">#{spec},</if>
            <if test="colorNo != null">#{colorNo},</if>
            <if test="grade != null">#{grade},</if>
            <if test="boxRate != null">#{boxRate},</if>
            <if test="purchasePrice != null">#{purchasePrice},</if>
            <if test="salePrice != null">#{salePrice},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsProduct" parameterType="ImsProduct">
        update ims_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="productCode != null and productCode != ''">product_code = #{productCode},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="unitId != null">unit_id = #{unitId},</if>
            <if test="brandId != null">brand_id = #{brandId},</if>
            <if test="spec != null">spec = #{spec},</if>
            <if test="colorNo != null">color_no = #{colorNo},</if>
            <if test="grade != null">grade = #{grade},</if>
            <if test="boxRate != null">box_rate = #{boxRate},</if>
            <if test="purchasePrice != null">purchase_price = #{purchasePrice},</if>
            <if test="salePrice != null">sale_price = #{salePrice},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsProductById" parameterType="Long">
        delete from ims_product where id = #{id}
    </delete>

    <delete id="deleteImsProductByIds" parameterType="String">
        delete from ims_product where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
