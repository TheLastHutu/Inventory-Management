<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ims.mapper.ImsDamageMapper">
    
    <resultMap type="ImsDamage" id="ImsDamageResult">
        <result property="id"    column="id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="enterpriseId"    column="enterprise_id"    />
        <result property="enterpriseName"    column="enterprise_name"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="warehouseName"    column="warehouse_name"    />
        <result property="billDate"    column="bill_date"    />
        <result property="reason"    column="reason"    />
        <result property="totalQtyPiece"    column="total_qty_piece"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="billStatus"    column="bill_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="ImsDamageImsDamageItemResult" type="ImsDamage" extends="ImsDamageResult">
        <collection property="imsDamageItemList" ofType="ImsDamageItem" column="id" select="selectImsDamageItemList" />
    </resultMap>

    <resultMap type="ImsDamageItem" id="ImsDamageItemResult">
        <result property="id"    column="id"    />
        <result property="damageId"    column="damage_id"    />
        <result property="lineNo"    column="line_no"    />
        <result property="productId"    column="product_id"    />
        <result property="qtyPiece"    column="qty_piece"    />
        <result property="costPrice"    column="cost_price"    />
        <result property="amount"    column="amount"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectImsDamageVo">
        select d.id, d.bill_no, d.enterprise_id, e.enterprise_name, d.warehouse_id, w.warehouse_name,
               d.bill_date, d.reason, d.total_qty_piece, d.total_amount, d.bill_status,
               d.create_by, d.create_time, d.update_by, d.update_time, d.remark
        from ims_damage d
        left join ims_enterprise e on d.enterprise_id = e.id
        left join ims_warehouse w on d.warehouse_id = w.id
    </sql>

    <select id="selectImsDamageList" parameterType="ImsDamage" resultMap="ImsDamageResult">
        <include refid="selectImsDamageVo"/>
        <where>  
            <if test="billNo != null  and billNo != ''"> and d.bill_no = #{billNo}</if>
            <if test="enterpriseId != null "> and d.enterprise_id = #{enterpriseId}</if>
            <if test="warehouseId != null "> and d.warehouse_id = #{warehouseId}</if>
            <if test="billDate != null and params.beginBillDate == null and params.endBillDate == null"> and d.bill_date = #{billDate}</if>
            <if test="params.beginBillDate != null and params.beginBillDate != ''"> and date_format(d.bill_date,'%Y%m%d') &gt;= date_format(#{params.beginBillDate},'%Y%m%d')</if>
            <if test="params.endBillDate != null and params.endBillDate != ''"> and date_format(d.bill_date,'%Y%m%d') &lt;= date_format(#{params.endBillDate},'%Y%m%d')</if>
            <if test="billStatus != null  and billStatus != ''"> and d.bill_status = #{billStatus}</if>
        </where>
        order by d.bill_date desc, d.create_time desc, d.id desc
    </select>
    
    <select id="selectImsDamageById" parameterType="Long" resultMap="ImsDamageImsDamageItemResult">
        select id, bill_no, enterprise_id, warehouse_id, bill_date, reason, total_qty_piece, total_amount, bill_status, create_by, create_time, update_by, update_time, remark
        from ims_damage
        where id = #{id}
    </select>

    <select id="selectImsDamageItemList" resultMap="ImsDamageItemResult">
        select id, damage_id, line_no, product_id, qty_piece, cost_price, amount, remark
        from ims_damage_item
        where damage_id = #{damage_id}
    </select>

    <insert id="insertImsDamage" parameterType="ImsDamage" useGeneratedKeys="true" keyProperty="id">
        insert into ims_damage
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="enterpriseId != null">enterprise_id,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="billDate != null">bill_date,</if>
            <if test="reason != null">reason,</if>
            <if test="totalQtyPiece != null">total_qty_piece,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="billStatus != null and billStatus != ''">bill_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="enterpriseId != null">#{enterpriseId},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="billDate != null">#{billDate},</if>
            <if test="reason != null">#{reason},</if>
            <if test="totalQtyPiece != null">#{totalQtyPiece},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">#{billStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateImsDamage" parameterType="ImsDamage">
        update ims_damage
        <trim prefix="SET" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="enterpriseId != null">enterprise_id = #{enterpriseId},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="billDate != null">bill_date = #{billDate},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="totalQtyPiece != null">total_qty_piece = #{totalQtyPiece},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="billStatus != null and billStatus != ''">bill_status = #{billStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteImsDamageById" parameterType="Long">
        delete from ims_damage where id = #{id}
    </delete>

    <delete id="deleteImsDamageByIds" parameterType="String">
        delete from ims_damage where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteImsDamageItemByDamageIds" parameterType="String">
        delete from ims_damage_item where damage_id in 
        <foreach item="damageId" collection="array" open="(" separator="," close=")">
            #{damageId}
        </foreach>
    </delete>

    <delete id="deleteImsDamageItemByDamageId" parameterType="Long">
        delete from ims_damage_item where damage_id = #{damageId}
    </delete>

    <insert id="batchImsDamageItem">
        insert into ims_damage_item( id, damage_id, line_no, product_id, qty_piece, cost_price, amount, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.damageId}, #{item.lineNo}, #{item.productId}, #{item.qtyPiece}, #{item.costPrice}, #{item.amount}, #{item.remark})
        </foreach>
    </insert>
</mapper>
